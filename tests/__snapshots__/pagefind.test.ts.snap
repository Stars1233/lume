}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-trigger-label.wrap,
:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-option-label.wrap {
    white-space: normal;
    line-height: 1.3;
}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-arrow {
    width: 10px;
    height: 6px;
    flex-shrink: 0;
