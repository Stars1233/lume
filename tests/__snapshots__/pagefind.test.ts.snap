}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#)
    .pf-dropdown-clear:hover:not([aria-disabled=\\"true\\"]) {
    background: var(--pf-hover);
    border-color: var(--pf-border);
