    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
    transition: transform 0.15s;
}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#)
    details.pf-filter-group:not([open])
    > summary.pf-filter-group-title::after {
    transform: rotate(-90deg);
}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#)
    [dir=\\"rtl\\"]
    details.pf-filter-group:not([open])
