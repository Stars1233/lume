    transition: border-color 0.15s;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-trigger:hover {
    border-color: var(--pf-border-focus);
}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-trigger.open {
