}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
}

:is(*, #\\\\#):is(*, #\\\\#):is(*, #\\\\#) .pf-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: var(--pf-input-height);
    padding: 0 12px;
